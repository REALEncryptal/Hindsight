					"$path": "example/client"
				}
			}
		},

		"Workspace": {
			"$properties": {
				"FilteringEnabled": true
			},

			"Map": {
				"$className": "Folder"
			},

			"Bullets": {
				"$className": "Folder"
			},

			"Characters": {
				"$className": "Folder"
			}
		}
